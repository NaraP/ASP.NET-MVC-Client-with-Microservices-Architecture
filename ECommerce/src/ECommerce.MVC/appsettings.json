{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiUrls": {
    "Inventory": "http://localhost:5001",
    "Order": "http://localhost:5002",
    "Payment": "http://localhost:5003",
    "Auth": "http://localhost:5004"
  },
  "Jwt": {
    "Key": "TechStore_SuperSecret_JWT_Key_2025_MustBe32CharsLong!",
    "Issuer": "TechStore",
    "Audience": "TechStoreApis",
    "ExpiryMinutes": 120
  },

    "HttpClient": {
      "TimeoutSeconds": 300
    },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/MvcClientlog-.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}

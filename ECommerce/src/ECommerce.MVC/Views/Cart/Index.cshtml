@model CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a href="@Url.Action("Index","Home")" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Continue Shopping
    </a>
    <h4 class="fw-bold mb-0">Shopping Cart</h4>
    <span class="badge bg-primary ms-1">@Model.ItemCount items</span>
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size:4rem;color:#ccc;"></i>
        <h5 class="text-muted mt-3">Your cart is empty</h5>
        <a href="@Url.Action("Index","Home")" class="btn btn-brand mt-2">
            <i class="bi bi-grid me-1"></i>Browse Products
        </a>
    </div>
}
else
{
    <div class="row g-4">
        <!-- Cart Items -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-0">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center p-3 border-bottom gap-3">
                            <img src="@item.ImageUrl" alt="@item.ProductName"
                                 style="width:70px;height:55px;object-fit:cover;border-radius:8px;" />
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-semibold">@item.ProductName</h6>
                                <small class="text-muted">$@item.UnitPrice.ToString("N2") each</small>
                            </div>

                            <!-- Quantity controls -->
                            <form method="post" action="@Url.Action("UpdateQuantity","Cart")" class="d-flex align-items-center gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                        class="btn btn-outline-secondary btn-sm px-2">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <span class="fw-bold px-2">@item.Quantity</span>
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                        class="btn btn-outline-secondary btn-sm px-2">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </form>

                            <span class="fw-bold text-primary" style="min-width:80px;text-align:right;">
                                $@item.TotalPrice.ToString("N2")
                            </span>

                            <form method="post" action="@Url.Action("Remove","Cart")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-link text-danger p-0 ms-2">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">Order Summary</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (@Model.ItemCount items)</span>
                        <span>$@Model.SubTotal.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success fw-medium">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tax (8%)</span>
                        <span>$@Model.Tax.ToString("N2")</span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span class="text-primary">$@Model.Total.ToString("N2")</span>
                    </div>

                    <a href="@Url.Action("Checkout","Order")" class="btn btn-brand w-100 py-2">
                        <i class="bi bi-credit-card me-2"></i>Proceed to Checkout
                    </a>

                    <div class="text-center mt-3">
                        <small class="text-muted">
                            <i class="bi bi-lock-fill me-1"></i>Secure 256-bit SSL encryption
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

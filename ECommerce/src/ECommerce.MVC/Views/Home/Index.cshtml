@model List<ProductViewModel>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Product Catalog</h4>
        <small class="text-muted">@Model.Count products found</small>
    </div>
</div>

<!-- Search & Filter -->
<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" class="form-control" placeholder="Search products..." value="@ViewBag.Search" />
            </div>
        </div>
        <div class="col-md-4">
            <select name="category" class="form-select" onchange="this.form.submit()">
                <option value="">All Categories</option>
                @foreach (var cat in (List<string>)ViewBag.Categories)
                {
                    <option value="@cat" selected="@(ViewBag.SelectedCategory == cat ? "selected" : null)">@cat</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-brand w-100">
                <i class="bi bi-funnel me-1"></i>Filter
            </button>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-search" style="font-size:3rem;color:#ccc;"></i>
        <h5 class="text-muted mt-3">No products found</h5>
        <a href="@Url.Action("Index")" class="btn btn-brand mt-2">Clear Filters</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <img src="@p.ImageUrl" class="product-img" alt="@p.Name" />
                    <div class="card-body d-flex flex-column">
                        <span class="badge badge-category mb-2 align-self-start">@p.Category</span>
                        <h6 class="card-title fw-semibold mb-1">@p.Name</h6>
                        <p class="text-muted small flex-grow-1" style="font-size:.78rem;">@p.Description</p>

                        <div class="rating mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(p.Rating) ? "bi-star-fill" : "bi-star")"></i>
                            }
                            <span class="text-muted ms-1" style="font-size:.78rem;">(@p.Rating)</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-bold fs-5 text-primary">$@p.Price.ToString("N2")</span>
                            <small class="text-muted">@p.Stock in stock</small>
                        </div>

                        @if (p.Stock > 0)
                        {
                            <form method="post" action="@Url.Action("Add","Cart")" class="mt-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id" />
                                <input type="hidden" name="quantity"  value="1" />
                                <button type="submit" class="btn btn-brand w-100 btn-sm">
                                    <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100 btn-sm mt-3" disabled>Out of Stock</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

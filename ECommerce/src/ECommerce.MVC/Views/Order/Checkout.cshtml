@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a href="@Url.Action("Index","Cart")" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Cart
    </a>
    <h4 class="fw-bold mb-0">Checkout</h4>
</div>

@if (TempData["PaymentError"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["PaymentError"]
    </div>
}

<form method="post" action="@Url.Action("PlaceOrder","Order")">
    @Html.AntiForgeryToken()
    <div class="row g-4">

        <!-- Left: Shipping + Payment -->
        <div class="col-lg-7">

            <!-- Shipping Address -->
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-geo-alt text-primary me-2"></i>Shipping Address
                    </h5>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-medium">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="John Smith" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium">Street Address</label>
                            <input asp-for="Address" class="form-control" placeholder="123 Main Street" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">City</label>
                            <input asp-for="City" class="form-control" placeholder="New York" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-medium">ZIP Code</label>
                            <input asp-for="ZipCode" class="form-control" placeholder="10001" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-medium">Country</label>
                            <select asp-for="Country" class="form-select">
                                <option>United States</option>
                                <option>Canada</option>
                                <option>United Kingdom</option>
                                <option>Australia</option>
                                <option>Germany</option>
                                <option>India</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment -->
            <div class="card">
                <div class="card-body">
                    <h5 class="fw-bold mb-1">
                        <i class="bi bi-credit-card text-primary me-2"></i>Payment Details
                    </h5>
                    <p class="text-muted small mb-4">Use card ending <strong>0000</strong> to simulate a failed payment.</p>

                    <!-- Payment Method -->
                    <div class="d-flex gap-3 mb-4">
                        @foreach (var method in new[] { "Credit Card", "Debit Card" })
                        {
                            <div class="form-check border rounded p-3 flex-grow-1" style="cursor:pointer;">
                                <input class="form-check-input" type="radio" name="PaymentMethod"
                                       id="pm_@method.Replace(" ","")" value="@method"
                                       checked="@(Model.PaymentMethod == method ? "checked" : null)" />
                                <label class="form-check-label fw-medium" for="pm_@method.Replace(" ","")">
                                    <i class="bi bi-credit-card me-1"></i>@method
                                </label>
                            </div>
                        }
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-medium">Card Number</label>
                            <input asp-for="CardNumber" class="form-control" placeholder="1234 5678 9012 3456"
                                   maxlength="19" id="cardNumber" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium">Cardholder Name</label>
                            <input asp-for="CardHolder" class="form-control" placeholder="John Smith" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Expiry Date</label>
                            <input asp-for="ExpiryDate" class="form-control" placeholder="MM/YY" maxlength="5" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">CVV</label>
                            <input asp-for="Cvv" class="form-control" placeholder="•••" maxlength="4" required />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Order Summary -->
        <div class="col-lg-5">
            <div class="card sticky-top" style="top:16px;">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">Your Order</h5>

                    @foreach (var item in Model.Cart.Items)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
                            <img src="@item.ImageUrl" style="width:40px;height:32px;object-fit:cover;border-radius:6px;" alt="" />
                            <div class="flex-grow-1 ms-1">
                                <div class="small fw-medium">@item.ProductName</div>
                                <div class="text-muted" style="font-size:.72rem;">Qty: @item.Quantity</div>
                            </div>
                            <span class="small fw-semibold">$@item.TotalPrice.ToString("N2")</span>
                        </div>
                    }

                    <hr />
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted">Subtotal</span>
                        <span>$@Model.Cart.SubTotal.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">Tax (8%)</span>
                        <span>$@Model.Cart.Tax.ToString("N2")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span class="text-primary">$@Model.Cart.Total.ToString("N2")</span>
                    </div>

                    <button type="submit" class="btn btn-brand w-100 py-2 fw-medium" id="placeOrderBtn">
                        <i class="bi bi-bag-check me-2"></i>Place Order — $@Model.Cart.Total.ToString("N2")
                    </button>

                    <div class="text-center mt-3">
                        <small class="text-muted">
                            <i class="bi bi-shield-check me-1 text-success"></i>
                            Payment secured by TechStore Pay
                        </small>
                    </div>
                </div>
            </div>
        </div>

    </div>
</form>

@section Scripts {
<script>
    // Card number formatting
    document.getElementById('cardNumber').addEventListener('input', function (e) {
        let val = e.target.value.replace(/\D/g, '').substring(0, 16);
        e.target.value = val.replace(/(.{4})/g, '$1 ').trim();
    });

    // Show loading on submit
    document.querySelector('form').addEventListener('submit', function () {
        const btn = document.getElementById('placeOrderBtn');
        btn.disabled   = true;
        btn.innerHTML  = '<span class="spinner-border spinner-border-sm me-2"></span>Processing payment...';
    });
</script>
}

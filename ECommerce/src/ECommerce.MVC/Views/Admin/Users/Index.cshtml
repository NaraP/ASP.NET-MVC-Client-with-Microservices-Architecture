@model UserListViewModel
@{
    ViewData["Title"] = "User Management";
    var roleColors = new Dictionary<string, string> {
        ["Admin"]    = "danger",
        ["Manager"]  = "success",
        ["Support"]  = "warning",
        ["Customer"] = "primary"
    };
}

@section Styles {
<style>
    .admin-sidebar {
        width: 220px; min-height: calc(100vh - 60px);
        background: #1e1b4b; position: fixed; top: 60px; left: 0; z-index: 100;
        padding-top: 1rem;
    }
    .admin-sidebar .nav-link { color: #a5b4fc; padding: .6rem 1.2rem; border-radius: 8px; margin: 2px 8px; }
    .admin-sidebar .nav-link:hover, .admin-sidebar .nav-link.active { background: #6C63FF; color: #fff; }
    .admin-sidebar .nav-link i { width: 20px; }
    .admin-content { margin-left: 220px; }
    .stat-card { border-radius: 14px; border: none; }
    .user-avatar { width: 38px; height: 38px; border-radius: 50%; display:inline-flex; align-items:center; justify-content:center; font-weight:700; font-size:.9rem; color:#fff; }
    .table-hover tbody tr:hover { background: #f0efff; }
    .filter-bar { background: #fff; border-radius: 12px; padding: 1rem; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .badge-role { font-size: .72rem; padding: .3em .6em; border-radius: 20px; }
</style>
}

<div class="admin-sidebar d-none d-lg-block">
    <div class="px-3 pb-2 mb-2 border-bottom border-indigo-800">
        <span class="text-white fw-bold"><i class="bi bi-shield-lock-fill me-2" style="color:#6C63FF"></i>Admin Panel</span>
    </div>
    <nav class="nav flex-column">
        <a class="nav-link active" href="@Url.Action("Index","AdminUsers")">
            <i class="bi bi-people me-2"></i>Users
        </a>
        <a class="nav-link" href="@Url.Action("Index","AdminRoles")">
            <i class="bi bi-tags me-2"></i>Roles
        </a>
        <hr class="border-secondary mx-3 my-2" />
        <a class="nav-link" href="@Url.Action("Index","Home")">
            <i class="bi bi-shop me-2"></i>Back to Store
        </a>
    </nav>
</div>

<div class="admin-content">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-people-fill me-2" style="color:#6C63FF"></i>User Management</h4>
            <p class="text-muted small mb-0">Create accounts, assign roles, and control access</p>
        </div>
        <a href="@Url.Action("Create","AdminUsers")" class="btn btn-sm text-white fw-medium" style="background:#6C63FF">
            <i class="bi bi-person-plus me-1"></i>New User
        </a>
    </div>

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        @foreach (var (label, value, icon, color) in new[]{
            ("Total Users",   Model.Users.Count.ToString(),                     "bi-people",         "primary"),
            ("Active",        Model.ActiveUsers.ToString(),                     "bi-person-check",   "success"),
            ("Inactive",      (Model.Users.Count - Model.ActiveUsers).ToString(),"bi-person-x",      "warning"),
            ("Roles Defined", Model.Roles.Count.ToString(),                     "bi-tags",           "info")
        })
        {
            <div class="col-6 col-md-3">
                <div class="card stat-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 p-2 bg-@color bg-opacity-10">
                            <i class="bi @icon fs-5 text-@color"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-5">@value</div>
                            <div class="text-muted small">@label</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Filter bar -->
    <div class="filter-bar mb-4">
        <form method="get" action="@Url.Action("Index","AdminUsers")" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label small fw-medium mb-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@Model.Search"
                           class="form-control" placeholder="Name or email..." />
                </div>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small fw-medium mb-1">Role</label>
                <select name="filterRole" class="form-select">
                    <option value="">All Roles</option>
                    @foreach (var r in Model.Roles)
                    {
                        <option value="@r.Name" selected="@(Model.FilterRole == r.Name)">@r.Name</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small fw-medium mb-1">Status</label>
                <select name="filterActive" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="true"  selected="@(Model.FilterActive == true)">Active</option>
                    <option value="false" selected="@(Model.FilterActive == false)">Inactive</option>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm text-white flex-fill" style="background:#6C63FF">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a href="@Url.Action("Index","AdminUsers")" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>

    <!-- Users table -->
    <div class="card">
        <div class="card-body p-0">
            @if (!Model.Users.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>
                    No users match your filters.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">User</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th>Status</th>
                                <th>Last Login</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                var primary = user.Roles.FirstOrDefault() ?? "Customer";
                                var avatarColor = roleColors.GetValueOrDefault(primary, "secondary");
                                var initials = string.Concat(user.FullName.Split(' ')
                                                   .Take(2).Select(w => w.Length > 0 ? w[0].ToString() : ""));
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="user-avatar bg-@avatarColor">@initials</span>
                                            <div>
                                                <div class="fw-medium small">@user.FullName</div>
                                                <div class="text-muted" style="font-size:.72rem">ID: @user.Id</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small text-muted">@user.Email</td>
                                    <td>
                                        @foreach (var role in user.Roles)
                                        {
                                            var c = roleColors.GetValueOrDefault(role, "secondary");
                                            <span class="badge badge-role bg-@c bg-opacity-15 text-@c border border-@c border-opacity-25 me-1">@role</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success bg-opacity-15 text-success border border-success border-opacity-25">
                                                <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-15 text-warning border border-warning border-opacity-25">
                                                <i class="bi bi-circle me-1" style="font-size:.5rem"></i>Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToString("MMM d, yyyy") : "Never")
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group btn-group-sm">
                                            <a href="@Url.Action("Details","AdminUsers",new{id=user.Id})"
                                               class="btn btn-outline-secondary" title="Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit","AdminUsers",new{id=user.Id})"
                                               class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (user.IsActive)
                                            {
                                                <form method="post" action="@Url.Action("Deactivate","AdminUsers")" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                    <button class="btn btn-outline-warning" title="Deactivate"
                                                            onclick="return confirm('Deactivate @user.FullName?')">
                                                        <i class="bi bi-person-dash"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" action="@Url.Action("Activate","AdminUsers")" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                    <button class="btn btn-outline-success" title="Activate">
                                                        <i class="bi bi-person-check"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="card-footer bg-transparent text-muted small py-2 px-3">
            Showing @Model.Users.Count user(s)
            @if (!string.IsNullOrWhiteSpace(Model.Search)) { <span> · search "@Model.Search"</span> }
            @if (!string.IsNullOrWhiteSpace(Model.FilterRole)) { <span> · role @Model.FilterRole</span> }
        </div>
    </div>
</div>

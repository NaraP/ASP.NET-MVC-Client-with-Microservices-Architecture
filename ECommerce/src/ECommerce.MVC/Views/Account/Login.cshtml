@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Sign In — TechStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <style>

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background: linear-gradient(-45deg,#6C63FF,#574fd6,#3f3d8b,#2c2a6a);
            background-size: 400% 400%;
            animation: gradientMove 12s ease infinite;
        }

     

        .login-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 25px 60px rgba(0,0,0,.3);
        }

        .brand-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg,#6C63FF,#ff6584);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
        }

        .btn-primary {
            background: #6C63FF;
            border-color: #6C63FF;
        }

            .btn-primary:hover {
                background: #574fd6;
                border-color: #574fd6;
            }

        .password-toggle {
            cursor: pointer;
        }

        .demo-pill {
            background: #f0eeff;
            color: #6C63FF;
            font-size: .75rem;
            border-radius: 20px;
            padding: 4px 12px;
            cursor: pointer;
            transition: .2s;
        }

            .demo-pill:hover {
                background: #e0dcff;
            }
    </style>

</head>

<body>

    <div class="container">
        <div class="row justify-content-center">

            <div class="col-md-5 col-lg-4">

                <div class="card login-card p-4 p-md-5">

                    <!-- Brand -->
                    <div class="text-center mb-4">

                        <div class="brand-icon mx-auto mb-3">
                            <i class="bi bi-lightning-charge-fill"></i>
                        </div>

                        <h2 class="fw-bold mb-1">TechStore</h2>
                        <p class="text-muted small">Sign in to your account</p>

                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 small">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">

                        @Html.AntiForgeryToken()

                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <!-- Email -->
                        <div class="form-floating mb-3">

                            <input asp-for="Email"
                                   class="form-control"
                                   id="Email"
                                   placeholder="you@example.com" />

                            <label>Email address</label>

                            <span asp-validation-for="Email" class="text-danger small"></span>

                        </div>

                        <!-- Password -->
                        <div class="form-floating mb-3 position-relative">

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   id="Password"
                                   placeholder="Password" />

                            <label>Password</label>

                            <span class="position-absolute top-50 end-0 translate-middle-y me-3 password-toggle"
                                  onclick="togglePassword()">
                                <i class="bi bi-eye"></i>
                            </span>

                            <span asp-validation-for="Password" class="text-danger small"></span>

                        </div>

                        <!-- Remember / Forgot -->
                        <div class="d-flex justify-content-between align-items-center mb-4">

                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label small">
                                    Remember me
                                </label>
                            </div>

                            <a asp-action="ForgotPassword"
                               asp-controller="Account"
                               class="small text-decoration-none">

                                Forgot password?

                            </a>

                        </div>

                        <!-- Login button -->
                        <button type="submit"
                                class="btn btn-primary w-100 py-2 fw-medium"
                                id="loginBtn">

                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Sign In

                        </button>

                    </form>

                    <hr class="my-4" />

                    <!-- Register link -->
                    <div class="text-center small mb-3">

                        <span class="text-muted">
                            Don't have an account?
                        </span>

                        <a asp-action="Register"
                           asp-controller="Account"
                           class="fw-semibold text-decoration-none ms-1">

                            <i class="bi bi-person-plus me-1"></i>
                            Create Account

                        </a>

                    </div>

                    <!-- Demo accounts -->
                    <p class="text-muted small text-center mb-2">
                        Demo accounts (click to fill):
                    </p>

                    <div class="d-flex flex-wrap gap-2 justify-content-center">

                        <span class="demo-pill"
                              onclick="fillDemo('demo@example.com','demo')">

                            <i class="bi bi-person me-1"></i>
                            demo / demo

                        </span>

                        <span class="demo-pill"
                              onclick="fillDemo('john@example.com','password123')">

                            <i class="bi bi-person me-1"></i>
                            john

                        </span>

                        <span class="demo-pill"
                              onclick="fillDemo('admin@example.com','admin123')">

                            <i class="bi bi-shield me-1"></i>
                            admin

                        </span>

                    </div>

                </div>
            </div>
        </div>
    </div>

    <script>

        function togglePassword(){

        let field=document.getElementById("Password");
        let icon=document.querySelector(".password-toggle i");

        if(field.type==="password"){
        field.type="text";
        icon.classList.replace("bi-eye","bi-eye-slash");
        }else{
        field.type="password";
        icon.classList.replace("bi-eye-slash","bi-eye");
        }

        }

        function fillDemo(email,password){

        document.getElementById("Email").value=email;
        document.getElementById("Password").value=password;

        }

        document.getElementById("loginForm").addEventListener("submit",function(){

        let btn=document.getElementById("loginBtn");

        btn.disabled=true;
        btn.innerHTML='<span class="spinner-border spinner-border-sm me-2"></span>Signing in...';

        });

    </script>

</body>
</html>